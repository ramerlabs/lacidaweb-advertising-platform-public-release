# Database — dedicated Neon/Postgres project for lacidaweb
# Create at https://console.neon.tech → New Project → "lacidaweb" → copy connection string
DATABASE_URL="postgresql://user:password@host:5432/lacidaweb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Production: https://lacidaweb.com
NEXTAUTH_SECRET="generate-a-long-random-secret"
# Optional: share session cookie across apex + www (example: .lacidaweb.com)
# NEXTAUTH_COOKIE_DOMAIN=".lacidaweb.com"

# RamerLabs License Manager (platform license for this deployment)
# Purchase / generate at https://ramerlabs.com — activate in Admin → License
LACIDAWEB_LICENSE_KEY=""
RLM_PRODUCT_SLUG="lacidaweb-advertising-platform"
# Internal only — do not expose in client UI
# RLM_LICENSE_SERVER="https://ramerlabs.com"

# Social login (optional — also enable in Admin → Integrations)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
# OAuth redirect URLs:
#   {NEXTAUTH_URL}/api/auth/callback/google
#   {NEXTAUTH_URL}/api/auth/callback/facebook

# Zernio
ZERNIO_API_KEY="sk_your_zernio_api_key"
ZERNIO_WEBHOOK_SECRET="your_webhook_hmac_secret"
APP_URL="http://localhost:3000"
# Production: https://lacidaweb.com

# Optional pricing tuning (for landing page plan calculator)
NEXT_PUBLIC_ZERNIO_COST_PER_ACCOUNT="12"

# Optional payment links (for checkout buttons)
NEXT_PUBLIC_PAYMENT_LINK_STARTER=""
NEXT_PUBLIC_PAYMENT_LINK_GROWTH=""
NEXT_PUBLIC_PAYMENT_LINK_SCALE=""

# Platform owner admin accounts (comma-separated emails)
ADMIN_EMAILS="owner@example.com"

# Optional Telegram admin alerts (can also configure in Admin → Integrations)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional SMTP email (can also configure in Admin → Integrations)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""

# USDT TRC20 auto-verification (Tron network)
USDT_TRC20_WALLET="YOUR_TRC20_WALLET_ADDRESS"
# Optional: fixed USD per 1 USDT (omit to use CoinGecko live rate)
# USDT_PER_USD="1"

# Payment instruction text shown to clients on checkout
USDT_PAYMENT_INSTRUCTIONS="Send USDT to wallet: YOUR_WALLET and include transaction hash."
PAYPAL_PAYMENT_INSTRUCTIONS="Pay via PayPal to: your-paypal@email.com and upload receipt."
GCASH_PAYMENT_INSTRUCTIONS="Pay to GCash number: 09XXXXXXXXX and upload screenshot proof."
