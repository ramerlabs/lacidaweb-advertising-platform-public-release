# Database (Neon / Supabase / Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/zernio_social?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Production: https://vccandbank.com  (use apex OR www consistently — not mixed)
NEXTAUTH_SECRET="generate-a-long-random-secret"
# Optional: share session cookie across apex + www (example: .vccandbank.com)
# NEXTAUTH_COOKIE_DOMAIN=".vccandbank.com"

# Zernio
ZERNIO_API_KEY="sk_your_zernio_api_key"
ZERNIO_WEBHOOK_SECRET="your_webhook_hmac_secret"
APP_URL="http://localhost:3000"
# Production: https://vccandbank.com

# Optional pricing tuning (for landing page plan calculator)
NEXT_PUBLIC_ZERNIO_COST_PER_ACCOUNT="12"

# Optional payment links (for checkout buttons)
NEXT_PUBLIC_PAYMENT_LINK_STARTER=""
NEXT_PUBLIC_PAYMENT_LINK_GROWTH=""
NEXT_PUBLIC_PAYMENT_LINK_SCALE=""

# Platform owner admin accounts (comma-separated emails)
ADMIN_EMAILS="owner@example.com"

# Optional Telegram admin alerts (can also configure in Admin → Integrations)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Optional SMTP email (can also configure in Admin → Integrations)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""

# USDT TRC20 auto-verification (Tron network)
USDT_TRC20_WALLET="YOUR_TRC20_WALLET_ADDRESS"
# Optional: fixed USD per 1 USDT (omit to use CoinGecko live rate)
# USDT_PER_USD="1"

# Payment instruction text shown to clients on checkout
USDT_PAYMENT_INSTRUCTIONS="Send USDT to wallet: YOUR_WALLET and include transaction hash."
PAYPAL_PAYMENT_INSTRUCTIONS="Pay via PayPal to: your-paypal@email.com and upload receipt."
GCASH_PAYMENT_INSTRUCTIONS="Pay to GCash number: 09XXXXXXXXX and upload screenshot proof."
