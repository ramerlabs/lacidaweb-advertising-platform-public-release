generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentMethod {
  USDT
  PAYPAL
  GCASH
  US_BANK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

// ─── lacidaweb advertising domain ───────────────────────────────────────────

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  CONVERSIONS
}

enum CampaignLifecycleStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum AdCreativeStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  PAUSED
}

enum BudgetType {
  DAILY
  LIFETIME
}

enum PublisherAdServingMode {
  ROTATE_ALL
  PERSONALIZED
}

enum WalletTransactionType {
  TOP_UP
  AD_SPEND
  REFUND
  ADJUSTMENT
  PUBLISHER_EARNING
  PUBLISHER_PAYOUT
}

enum AdEventType {
  IMPRESSION
  CLICK
}

enum PublisherPayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELED
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum CampaignReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
  REQUESTED_CHANGES
}

enum PublisherSiteStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum AdPlacementFormat {
  BANNER
  LEADERBOARD
  RECTANGLE
  SKYSCRAPER
  MOBILE
  TEXT
  TEXT_INLINE
  TEXT_BOX
}

enum ClientAccountType {
  ADVERTISER
  PUBLISHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String            @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  accountType    ClientAccountType @default(ADVERTISER)
  bannedAt       DateTime?
  banReason      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    TeamMember[]
  auditLogs      AuditLog[]
  supportMessages SupportMessage[]
  supportTickets      SupportTicket[]  @relation("TicketCreator")
  reviewedCampaigns   AdCampaign[]     @relation("CampaignReviewedBy")
  campaignReviewActions CampaignReview[] @relation("CampaignReviewActor")
  publisherPayoutReviews PublisherPayout[] @relation("PublisherPayoutReviewer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  aiEnabled        Boolean  @default(false)
  aiBalanceCents   Int      @default(0)
  aiTokenBalance   Int      @default(0)
  adWalletBalanceCents Int  @default(0)
  publisherBalanceCents Int @default(0)
  publisherLifetimeEarnedCents Int @default(0)
  publisherLifetimePaidCents Int @default(0)
  lowTokenAlertAt  DateTime?
  businessName        String?
  businessDescription String?  @db.Text
  businessIndustry    String?
  businessAudience    String?  @db.Text
  businessWebsite     String?
  businessLocation    String?
  brandVoice          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members             TeamMember[]
  auditLogs           AuditLog[]
  subscription        Subscription?
  payments            Payment[]
  supportTickets      SupportTicket[]
  aiUsageLogs         AiUsageLog[]
  adCampaigns         AdCampaign[]
  walletTransactions  WalletTransaction[]
  publisherSites      PublisherSite[]
  publisherPayouts    PublisherPayout[]
  adEvents            AdEvent[]
}

model TeamMember {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  teamId    String
  userId    String?
  action    String
  message   String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([teamId, createdAt])
}

model Subscription {
  id             String             @id @default(cuid())
  teamId         String             @unique
  planId         String
  accountLimit   Int
  interval       BillingInterval    @default(MONTHLY)
  amount         Int
  currency       String             @default("USD")
  status         SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime       @default(now())
  currentPeriodEnd   DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  team     Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id             String        @id @default(cuid())
  teamId         String
  subscriptionId String?
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Int
  currency       String        @default("USD")
  usdtAmount     Float?
  interval       BillingInterval @default(MONTHLY)
  purpose        String        @default("SUBSCRIPTION")
  aiCreditsCents Int?
  aiTokensGranted Int?
  adCampaignId   String?
  adWalletTopUpCents Int?
  externalRef    String?
  txHash         String?       @unique
  notes          String?       @db.Text
  proofUrl       String?
  verifiedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  adCampaign   AdCampaign?   @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]

  @@index([teamId, status])
  @@index([createdAt])
  @@index([adCampaignId])
}

model SupportTicket {
  id          String        @id @default(cuid())
  teamId       String
  createdById  String
  subject      String
  description  String       @db.Text
  status       TicketStatus @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  team       Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  messages   SupportMessage[]

  @@index([teamId, status])
  @@index([createdAt])
}

model SupportMessage {
  id         String      @id @default(cuid())
  ticketId   String
  senderUserId String?
  senderRole String      @default("CLIENT")
  message    String      @db.Text
  createdAt  DateTime    @default(now())

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUser User?         @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
}

model PaymentSettings {
  id                 String   @id @default("default")
  usdtEnabled        Boolean  @default(true)
  paypalEnabled      Boolean  @default(true)
  gcashEnabled       Boolean  @default(true)
  usBankEnabled      Boolean  @default(false)
  usdtTrc20Wallet    String?
  paypalEmail        String?
  gcashNumber        String?
  usBankName         String?
  usBankAccountName  String?
  usBankAccountNumber String?
  usBankRoutingNumber String?
  usBankAccountType  String?
  usdtInstructions   String?  @db.Text
  paypalInstructions String?  @db.Text
  gcashInstructions  String?  @db.Text
  usBankInstructions String?  @db.Text
  usdtPerUsd         Float?
  updatedAt          DateTime @updatedAt
}

model SiteSettings {
  id                         String   @id @default("default")
  title                      String?
  product                    String?
  description                String?  @db.Text
  logoUrl                    String?
  logoDarkUrl                String?
  logoHeightPx               Int      @default(40)
  faviconUrl                 String?
  supportEmail               String?
  activityFeedDisplayCount   Int      @default(20)
  activityFeedSimulatedEnabled Boolean @default(true)
  updatedAt                  DateTime @updatedAt
}

model IntegrationSettings {
  id                  String   @id @default("default")
  telegramEnabled     Boolean  @default(false)
  telegramBotToken    String?
  telegramChatId      String?
  telegramNotifySupport   Boolean @default(true)
  telegramNotifyPayments  Boolean @default(true)
  telegramNotifyUsers     Boolean @default(true)
  smtpEnabled             Boolean @default(false)
  smtpHost                String?
  smtpPort                Int     @default(587)
  smtpSecure              Boolean @default(false)
  smtpUser                String?
  smtpPassword            String?
  smtpFromEmail           String?
  smtpFromName            String?
  smtpFallbackTelegram    Boolean @default(true)
  openaiApiKey            String?
  aiEnabled               Boolean @default(false)
  aiProfitMarginPercent   Int     @default(80)
  aiTextInputCostPerMillion  Float @default(0.15)
  aiTextOutputCostPerMillion Float @default(0.60)
  aiImageCostUsd          Float   @default(0.02)
  aiCreditPackUsd         Float   @default(10)
  aiCreditsPerPackCents   Int     @default(1000)
  aiTrialTokens             Int     @default(50000)
  aiLowTokenThreshold       Int     @default(50000)
  adsEnabled                Boolean @default(true)
  publisherAdServingMode    PublisherAdServingMode @default(ROTATE_ALL)
  publisherAdRotateSeconds  Int     @default(8)
  publisherAutoAdsEnabled   Boolean @default(true)
  /// When true, embed host must match the registered site domain or the allowlist.
  requireDomainApproval     Boolean @default(true)
  /// Newline/comma-separated hosts that may receive ads without a PublisherSite row.
  allowedAdDomains          String? @db.Text
  publisherCpmCents         Int     @default(100)
  publisherCpcCents         Int     @default(10)
  publisherMinPayoutCents   Int     @default(2500)
  /// Landing page: show synthetic impressions/clicks that keep growing; real events add on top.
  landingFakeStatsEnabled          Boolean  @default(true)
  landingFakeImpressionsBase       Int      @default(18420)
  landingFakeClicksBase            Int      @default(612)
  landingFakeImpressionsPerHour    Float    @default(180)
  landingFakeClicksPerHour         Float    @default(7.2)
  landingFakeStatsStartedAt        DateTime @default(now())
  adsProfitMarginPercent    Int     @default(55)
  adWalletTopUpUsd          Float   @default(25)
  /// House / fill promo when paid inventory is short (auto-ads pad up to max slots).
  houseAdHeadline           String?
  houseAdBody               String?  @db.Text
  houseAdCtaLabel           String?
  houseAdUrl                String?
  subscriptionProfitMarginPercent Int @default(80)
  googleOAuthEnabled        Boolean @default(true)
  facebookOAuthEnabled      Boolean @default(true)
  updatedAt           DateTime @updatedAt
}

/// Platform license for this lacidaweb deployment (RamerLabs License Manager).
model PlatformLicense {
  id              String    @id @default("default")
  licenseKey      String
  productSlug     String    @default("lacidaweb-advertising-platform")
  status          String?
  expiresAt       String?
  lastValidatedAt DateTime?
  payload         Json?
  updatedAt       DateTime  @updatedAt
}

model AdCampaign {
  id                 String   @id @default(cuid())
  teamId             String
  platformCampaignId String?
  platform           String
  adAccountId        String
  name               String
  goal               String
  objective          CampaignObjective?
  adType             String   @default("standalone")
  status             String   @default("pending_review")
  lifecycleStatus    CampaignLifecycleStatus @default(PENDING_REVIEW)
  budgetAmount       Float
  budgetType         String
  budgetTypeEnum     BudgetType?
  platformBudgetUsd  Float
  clientChargeUsd    Float
  lifetimeSpendCents Int      @default(0)
  paymentStatus      String   @default("pending_payment")
  paymentId          String?
  currency           String   @default("USD")
  headline           String?
  body               String?  @db.Text
  linkUrl            String?
  imageUrl           String?
  countries          String[] @default([])
  targeting          Json?
  scheduleStart      DateTime?
  scheduleEnd        DateTime?
  reviewedAt         DateTime?
  reviewedById       String?
  rejectionReason    String?  @db.Text
  metrics            Json?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewedBy       User?             @relation("CampaignReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  payments         Payment[]
  ads              Ad[]
  analyticsSnapshots AnalyticsSnapshot[]
  reviews          CampaignReview[]
  walletTransactions WalletTransaction[]

  @@index([teamId, status])
  @@index([teamId, lifecycleStatus])
  @@index([platformCampaignId])
  @@index([paymentStatus])
  @@index([scheduleStart, scheduleEnd])
}

/// Individual ad creative unit within a campaign (Facebook Ads "Ad" level).
model Ad {
  id              String           @id @default(cuid())
  campaignId      String
  name            String
  status          AdCreativeStatus @default(DRAFT)
  headline        String
  primaryText     String           @db.Text
  destinationUrl  String
  ctaLabel        String           @default("Learn More")
  imageUrl        String?
  videoUrl        String?
  sortOrder       Int              @default(0)
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
}

/// Website registered by a publisher to monetize with lacidaweb ads.
model PublisherSite {
  id             String              @id @default(cuid())
  teamId         String
  name           String
  domain         String
  status         PublisherSiteStatus @default(ACTIVE)
  autoAdsEnabled Boolean             @default(true)
  autoAdsKey     String?             @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  team       Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  placements AdPlacement[]

  @@unique([teamId, domain])
  @@index([teamId])
  @@index([autoAdsKey])
}

/// Ad slot on a publisher website — embed code uses placementKey.
model AdPlacement {
  id           String            @id @default(cuid())
  siteId       String
  name         String
  format       AdPlacementFormat @default(BANNER)
  width        Int               @default(728)
  height       Int               @default(90)
  placementKey String            @unique @default(cuid())
  autoSlot     String?
  isActive     Boolean           @default(true)
  impressions  Int               @default(0)
  clicks       Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  site PublisherSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([placementKey])
}

/// Per-event impression/click log for earnings + fraud filtering.
model AdEvent {
  id           String     @id @default(cuid())
  type         AdEventType
  teamId       String
  placementId  String
  adId         String?
  campaignId   String?
  visitorHash  String?
  ipHash       String?
  userAgent    String?    @db.Text
  isValid      Boolean    @default(true)
  fraudReason  String?
  earnedCents  Int        @default(0)
  createdAt    DateTime   @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([placementId, type, visitorHash, createdAt])
  @@index([placementId, type, ipHash, createdAt])
  @@index([isValid, createdAt])
}

/// Publisher withdrawal request — paid via enabled payment methods.
model PublisherPayout {
  id              String                @id @default(cuid())
  teamId          String
  amountCents     Int
  method          PaymentMethod
  status          PublisherPayoutStatus @default(PENDING)
  payoutDetails   String                @db.Text
  notes           String?               @db.Text
  adminNotes      String?               @db.Text
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("PublisherPayoutReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([teamId, status, createdAt])
  @@index([status, createdAt])
}

/// Immutable admin review audit trail for campaign moderation.
model CampaignReview {
  id          String               @id @default(cuid())
  campaignId  String
  reviewerId  String?
  action      CampaignReviewAction
  notes       String?              @db.Text
  createdAt   DateTime             @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewer User?      @relation("CampaignReviewActor", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
}

/// Wallet ledger — every balance change (top-ups, ad spend, refunds).
model WalletTransaction {
  id              String                  @id @default(cuid())
  teamId          String
  campaignId      String?
  paymentId       String?
  type            WalletTransactionType
  status          WalletTransactionStatus @default(PENDING)
  amountCents     Int
  balanceAfterCents Int?
  currency        String                  @default("USD")
  method          PaymentMethod?
  description     String?
  externalRef     String?
  metadata        Json?
  createdAt       DateTime                @default(now())
  completedAt     DateTime?

  team     Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  campaign AdCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  payment  Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([teamId, createdAt])
  @@index([teamId, type, status])
  @@index([campaignId])
  @@index([paymentId])
}

/// Time-series performance metrics for charts (daily rollups per campaign).
model AnalyticsSnapshot {
  id            String   @id @default(cuid())
  campaignId    String
  snapshotDate  DateTime @db.Date
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  spendCents    Int      @default(0)
  conversions   Int      @default(0)
  reach         Int      @default(0)
  ctr           Float    @default(0)
  cpcCents      Int      @default(0)
  cpmCents      Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, snapshotDate])
  @@index([campaignId, snapshotDate])
  @@index([snapshotDate])
}

model AiUsageLog {
  id                String   @id @default(cuid())
  teamId            String
  type              String
  providerCostCents Int
  chargedCents      Int
  tokensUsed        Int?
  promptTokens      Int?
  completionTokens  Int?
  createdAt         DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
}

model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
}
